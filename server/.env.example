# Backend Environment Configuration
# Copy this to server/.env and fill in your actual values

# ==========================================
# NODE ENVIRONMENT
# ==========================================
# development: Full logging, hot reload
# production: Optimized, minimal logging
# test: Test mode
NODE_ENV=development

# API Server Port
API_PORT=3001

# ==========================================
# DATABASE
# ==========================================
# PostgreSQL Connection String
# Format: postgresql://username:password@host:port/database
# 
# Using Docker Compose:
#   - Host: localhost
#   - Port: 5432
#   - User: etpc_user
#   - Password: etpc_password
#   - Database: email_tone_prompt
DATABASE_URL=postgresql://etpc_user:etpc_password@localhost:5432/email_tone_prompt

# ==========================================
# REDIS CACHE & QUEUE
# ==========================================
# Redis Connection String
# Format: redis://[:password@]host:port/database
# 
# Using Docker Compose:
#   - Host: localhost
#   - Port: 6379
#   - No password (default)
REDIS_URL=redis://localhost:6379

# ==========================================
# OPENAI API (For Tone Analysis)
# ==========================================
# Get your API key from: https://platform.openai.com/api-keys
# 
# Steps to get OpenAI API Key:
# 1. Go to https://platform.openai.com
# 2. Click on your profile → API keys
# 3. Click "Create new secret key"
# 4. Copy and paste it here
# 
# Note: Keep this secret! Never commit to git
OPENAI_API_KEY=sk-your-actual-openai-api-key-here

# ==========================================
# GMAIL OAUTH2
# ==========================================
# These are required for Gmail integration
# Get these from Google Cloud Console (see COMPLETE_SETUP_GUIDE.md)
# 
# Steps:
# 1. Go to https://console.cloud.google.com
# 2. Create new project
# 3. Enable Gmail API
# 4. Create OAuth 2.0 credentials
# 5. Copy credentials below

# Gmail OAuth2 Client ID
# Format: xxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com

# Gmail OAuth2 Client Secret
# Format: GOCSPX-xxxxxxx
GMAIL_CLIENT_SECRET=your-gmail-client-secret

# Gmail OAuth2 Redirect URI
# This must match exactly with your Google Cloud Console settings
GMAIL_REDIRECT_URI=http://localhost:3001/api/auth/gmail/callback

# ==========================================
# API AUTHENTICATION
# ==========================================
# Admin API Key for accessing admin endpoints
# Can be any string, used for admin dashboard access
API_KEY=dev-api-key-12345

# ==========================================
# EMAIL SCHEDULING
# ==========================================
# Cron schedule for fetching emails
# Format: minute hour day_of_month month day_of_week
# 
# Examples:
#   */15 * * * *     = Every 15 minutes
#   0 * * * *        = Every hour at :00
#   0 0 * * *        = Daily at midnight
#   0 9 * * 1-5      = Every weekday at 9 AM
EMAIL_FETCH_CRON=*/15 * * * *

# ==========================================
# OPTIONAL: JWT CONFIGURATION
# ==========================================
# JWT_SECRET=your-super-secret-jwt-key-here
# JWT_EXPIRY=15m
# REFRESH_TOKEN_EXPIRY=7d

# ==========================================
# OPTIONAL: EMAIL SENDING
# ==========================================
# For sending emails via the application
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@emailtone.com

# ==========================================
# OPTIONAL: LOGGING
# ==========================================
# LOG_LEVEL=debug
# LOG_FORMAT=json

# ==========================================
# OPTIONAL: CORS
# ==========================================
# CORS_ORIGIN=http://localhost:5173
# CORS_CREDENTIALS=true

# ==========================================
# OPTIONAL: RATE LIMITING
# ==========================================
# RATE_LIMIT_WINDOW=15m
# RATE_LIMIT_MAX_REQUESTS=100
